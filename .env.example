# =============================================================================
# BOT CONFIGURATION
# =============================================================================
# Bot ID from Azure Bot Service (Microsoft App ID)
BOT_ID=your-bot-id

# Bot Password (client secret) - NOT REQUIRED for Managed Identity
# For traditional authentication: Set BOT_PASSWORD to your client secret
# For managed identity: Leave empty and set AZURE_USE_MANAGED_IDENTITY=true
BOT_PASSWORD=your-bot-password

# Server port
PORT=3978

# Public URL for OAuth callbacks (required for OAuth mode)
PUBLIC_URL=https://your-bot-url

# =============================================================================
# AZURE MANAGED IDENTITY (Recommended for Production)
# =============================================================================
# Set to 'true' to use Azure Managed Identity instead of client secrets
# Benefits:
#   - No password/secret to manage or rotate
#   - Azure handles authentication automatically
#   - More secure than client secrets
#
# For User-Assigned Managed Identity (recommended):
#   AZURE_USE_MANAGED_IDENTITY=true
#   BOT_ID=<from Azure Bot> (Microsoft App ID)
#   AZURE_CLIENT_ID=<user-assigned identity client ID> (optional, for user-assigned)
#   AZURE_TENANT_ID=<your tenant ID> (optional)
#
# For App Service Managed Identity:
#   AZURE_USE_MANAGED_IDENTITY=true
#   BOT_ID=<from Azure Bot>
#   (System-assigned identity is used automatically)
#
# For local development without managed identity:
#   AZURE_USE_MANAGED_IDENTITY=false (or omit)
#   BOT_ID=<from Azure Bot>
#   BOT_PASSWORD=<client secret>
# =============================================================================
AZURE_USE_MANAGED_IDENTITY=false

# User-Assigned Managed Identity Client ID (optional)
# Only needed if you created a user-assigned managed identity
# AZURE_CLIENT_ID=<your-managed-identity-client-id>

# Azure Tenant ID (optional for single-tenant apps)
# AZURE_TENANT_ID=<your-tenant-id>

# Odoo Configuration
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your-database-name

# Gemini AI Configuration
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview

# Cache Configuration
PROJECT_CACHE_TTL=3600000  # 1 hour in milliseconds

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/bot.log

# Environment
NODE_ENV=production

# Public URL (required for OAuth callbacks)
PUBLIC_URL=https://your-bot-url

# =============================================================================
# AUTHENTICATION MODES
# =============================================================================
# AUTH_MODE determines how users authenticate with Odoo
# Valid values: admin_proxy | api_key | oauth | service_account
#
# 1. admin_proxy (RECOMMENDED for enterprise)
#    - Uses a single admin service account to log timesheets on behalf of users
#    - Automatically maps Teams users to Odoo users by matching their email
#    - Users don't need to authenticate - zero-friction onboarding
#    - Requires: ODOO_USERNAME and ODOO_PASSWORD (admin credentials)
#    - Requires: Users' Teams email must match their Odoo login email
#
# 2. api_key (RECOMMENDED for teams with self-service)
#    - Each user generates their own API Key in Odoo
#    - Users connect their account by providing the API Key to the bot
#    - Works with all Odoo versions including Odoo Online
#    - Requires: Users run "connect" command and enter their API Key
#
# 3. oauth (for self-hosted Odoo with OAuth provider)
#    - Users authenticate via OAuth flow
#    - Requires OAuth provider setup in Odoo.sh or self-hosted
#    - Requires: OAUTH_ENABLED=true and OAuth configuration below
#
# 4. service_account (TESTING ONLY - NOT FOR PRODUCTION)
#    - All users share the same Odoo account
#    - Timesheets are logged as the service account user
#    - Requires: ODOO_USERNAME and ODOO_PASSWORD
#    - ⚠️  WARNING: Not suitable for production - all users share same account!
# =============================================================================
AUTH_MODE=admin_proxy

# =============================================================================
# ADMIN CREDENTIALS (Required for admin_proxy and service_account modes)
# =============================================================================
# For admin_proxy mode:
#   - Use credentials for an admin account with rights to:
#     1. Read res.users to look up users by email
#     2. Create timesheets (account.analytic.line) for any user
#   - Timesheets are logged with the matched user's ID, not the admin's
#
# For service_account mode (testing only):
#   - All timesheets are logged as this user
# =============================================================================
ODOO_USERNAME=admin@yourcompany.com
ODOO_PASSWORD=your-admin-password

# =============================================================================
# OAUTH CONFIGURATION (Optional - only if AUTH_MODE=oauth or OAUTH_ENABLED=true)
# =============================================================================
# Set OAUTH_ENABLED=true to provide OAuth as an authentication option
# Note: OAuth only works with Odoo.sh or self-hosted Odoo with OAuth provider
OAUTH_ENABLED=false
ODOO_OAUTH_CLIENT_ID=your-oauth-client-id
ODOO_OAUTH_CLIENT_SECRET=your-oauth-client-secret
ODOO_OAUTH_REDIRECT_URI=https://your-bot-url/auth/oauth/callback
ODOO_OAUTH_AUTH_URL=https://your-odoo-instance.com/oauth/authorize
ODOO_OAUTH_TOKEN_URL=https://your-odoo-instance.com/oauth/token
ODOO_OAUTH_SCOPE=read write

# Token Storage Configuration (for api_key and oauth modes)
TOKEN_DB_PATH=./data/tokens.db
TOKEN_ENCRYPTION_KEY=YOUR_API_KEY_HERE
