# Bot Configuration
BOT_ID=your-bot-id
BOT_PASSWORD=your-bot-password
PORT=3978

# Odoo Configuration
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your-database-name
# ⚠️  Service Account credentials - TESTING ONLY
# Use ODOO_USERNAME/PASSWORD only when AUTH_MODE=service_account (not recommended for production)
# For production, use API Key or OAuth authentication per user
ODOO_USERNAME=your-username
ODOO_PASSWORD=your-password

# Gemini AI Configuration
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview

# Cache Configuration
PROJECT_CACHE_TTL=3600000  # 1 hour in milliseconds

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/bot.log

# Environment
NODE_ENV=production

# Public URL (required for OAuth callbacks)
PUBLIC_URL=https://your-bot-url

# Authentication Mode: api_key | oauth | service_account (testing only)
# - api_key: Per-user authentication with API Keys (RECOMMENDED - works with all Odoo versions)
# - oauth: OAuth2 flow (requires OAuth provider setup in Odoo.sh or self-hosted)
# - service_account: Single shared account mode (TESTING ONLY - uses ODOO_USERNAME/PASSWORD)
#                    ⚠️  ALL USERS SHARE THE SAME ACCOUNT - not suitable for production!
AUTH_MODE=api_key

# OAuth Configuration (Optional - enable OAuth as an auth option)
# Set OAUTH_ENABLED=true to provide OAuth as an authentication option
OAUTH_ENABLED=false
ODOO_OAUTH_CLIENT_ID=your-oauth-client-id
ODOO_OAUTH_CLIENT_SECRET=your-oauth-client-secret
ODOO_OAUTH_REDIRECT_URI=https://your-bot-url/auth/oauth/callback
ODOO_OAUTH_AUTH_URL=https://your-odoo-instance.com/oauth/authorize
ODOO_OAUTH_TOKEN_URL=https://your-odoo-instance.com/oauth/token
ODOO_OAUTH_SCOPE=read write

# Token Storage Configuration
TOKEN_DB_PATH=./data/tokens.db
TOKEN_ENCRYPTION_KEY=your-32-char-encryption-key-min
