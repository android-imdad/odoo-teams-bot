{
  "name": "odoo-teams-bot",
  "version": "1.0.0",
  "description": "Microsoft Teams bot for Odoo timesheet management using AI",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "validate": "ts-node -e \"import('./src/config/configValidation').then(m => console.log('Config validated'))\""
  },
  "keywords": [
    "teams",
    "bot",
    "odoo",
    "timesheet",
    "ai",
    "gemini"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "adaptivecards": "^3.0.0",
    "botbuilder": "^4.20.0",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "fuse.js": "^7.1.0",
    "restify": "^11.1.0",
    "winston": "^3.11.0",
    "xmlrpc": "^1.3.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/restify": "^8.5.12",
    "@types/xmlrpc": "^1.3.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
